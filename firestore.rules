rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // PUBLIC (unauthenticated)
    // -------------------------------------------------------------------------

    // Contact form: anyone can submit; only signed-in admin can read
    match /contactSubmissions/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // -------------------------------------------------------------------------
    // ADMIN (authenticated — any signed-in user has admin access)
    // -------------------------------------------------------------------------

    match /products/{id} {
      allow read, write: if request.auth != null;
    }
    match /orders/{id} {
      allow read, write: if request.auth != null;
    }
    match /quotations/{id} {
      allow read, write: if request.auth != null;
    }
    match /invoices/{id} {
      allow read, write: if request.auth != null;
    }

    // User profiles (created by create-admin-user script): read own doc only
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
  }
}
